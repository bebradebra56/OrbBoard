<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/orb_board_graph"
    app:startDestination="@id/orbBoardLoadFragment">

    <fragment
        android:id="@+id/orbBoardLoadFragment"
        android:name="com.orbboard.boardoar.nfre.presentation.ui.load.OrbBoardLoadFragment"
        android:label="OrbBoardLoadFragment" >
        <action
            android:id="@+id/action_orbBoardLoadFragment_to_orbBoardV"
            app:destination="@id/orbBoardV"
            app:popUpTo="@id/orb_board_graph"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/orbBoardV"
        android:name="com.orbboard.boardoar.nfre.presentation.ui.view.OrbBoardV"
        android:label="OrbBoardV" />
</navigation>